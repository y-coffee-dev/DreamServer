# Dream Server — Worker image (CPU + RPC, minimal)
# Only rpc-server binary, no llama-server. Used on worker nodes.
# Pin to the same llama.cpp tag across all cluster images.
ARG LLAMA_CPP_TAG=b8672

FROM ubuntu:24.04 AS build
ARG LLAMA_CPP_TAG
RUN apt-get update && apt-get install -y --no-install-recommends cmake make git g++ ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN git clone --depth 1 -b "${LLAMA_CPP_TAG}" https://github.com/ggerganov/llama.cpp /llama.cpp
WORKDIR /llama.cpp
RUN cmake -B build -DGGML_RPC=ON \
    && cmake --build build -j"$(nproc)" --target rpc-server

FROM ubuntu:24.04
COPY --from=build /llama.cpp/build/bin/rpc-server /usr/local/bin/
ENTRYPOINT ["rpc-server"]
# -c enables tensor caching at ~/.cache/llama.cpp/rpc (first load over network, then local)
# --host 0.0.0.0 required for cross-machine access (RPC has no auth — use trusted networks)
CMD ["-p", "50052", "-c", "--host", "0.0.0.0"]
